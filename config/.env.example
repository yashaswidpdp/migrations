# Odoo Source API (Legacy)
ODOO_BASE_URL=https://tool.dpdp-portal.dpdpconsultants.com/api
ODOO_JWT_TOKEN=your_jwt_token_here
ODOO_SESSION_ID=your_session_cookie_here
ODOO_DB=your_db_name

# Flask Destination API (New)
FLASK_API_BASE_URL=http://localhost:5000/api
FLASK_API_KEY=your_flask_api_key
# The Host header value for Flask tenant resolution (must match tenants.domain in DB)
FLASK_TENANT_DOMAIN=dpdpconsultants.com

# Migration Settings
BATCH_SIZE=50
LOG_LEVEL=INFO
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
LOGS_DIR=logs
# Set to a small number (e.g., 10) for test runs; 0 = no limit
MAX_RECORDS=0
# Concurrent workers for the by-id enrichment fan-out (consent/request).
# Pure I/O wait -> near-linear speedup. Lower if Odoo rate-limits / WAF blocks.
ENRICH_WORKERS=16
# Concurrent workers for the consent/request LOAD. Writes are sharded by
# principal (+ vendor for requests) so the same principal/vendor is never
# written by two workers at once. Lower than ENRICH_WORKERS since each request
# commits to the DB. Drop to 4 if the Flask DB shows contention.
LOAD_WORKERS=8
